# ==============================
# 中医知识库 - 环境变量配置
# 复制此文件为 .env 后修改
# ==============================

# API 密钥（用于内容上传/管理接口的认证，请修改为随机字符串）
API_KEY=changeme

# 本地数据目录（默认 ./data，Docker 中建议挂载到持久卷如 /data）
# DATA_DIR=./data

# 应用端口（默认 3000）
PORT=3000

# ==============================
# 以下为可选备份配置
# 不配置时应用完全正常运行，数据存储在本地
# 配置后数据会自动同步到对应服务作为备份
# ==============================

# PostgreSQL 数据库（可选，作为数据备份）
# DATABASE_URL=postgresql://user:password@host:5432/zhongyi

# S3 兼容对象存储（可选，作为文件备份）
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=zhongyi
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=
